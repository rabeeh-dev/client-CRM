<div class="task-board-card" draggable="true" ondragstart="drag(event)" data-task-id="<%= task._id %>">
    <div class="card-top-row">
        <span class="priority-badge priority-<%= task.priority %>"><%= task.priority %></span>
        
        <!-- Column Move buttons (useful on touchscreens or without drag-drop support) -->
        <div class="quick-move-controls" onclick="event.stopPropagation();">
            <% if (currentColumn === 'in_progress' || currentColumn === 'completed') { %>
                <% const prevStatus = currentColumn === 'completed' ? 'in_progress' : 'todo'; %>
                <button class="quick-move-btn" onclick="transitionTask('<%= task._id %>', '<%= prevStatus %>')" title="Move Back">
                    <i data-lucide="chevron-left" style="width: 12px; height: 12px;"></i>
                </button>
            <% } %>
            <% if (currentColumn === 'todo' || currentColumn === 'in_progress') { %>
                <% const nextStatus = currentColumn === 'todo' ? 'in_progress' : 'completed'; %>
                <button class="quick-move-btn" onclick="transitionTask('<%= task._id %>', '<%= nextStatus %>')" title="Move Forward">
                    <i data-lucide="chevron-right" style="width: 12px; height: 12px;"></i>
                </button>
            <% } %>
            
            <!-- Context Actions Menu -->
            <button class="quick-move-btn" onclick="toggleCardMenu('<%= task._id %>')" style="margin-left: 4px;" title="Actions">
                <i data-lucide="more-horizontal" style="width: 12px; height: 12px;"></i>
            </button>
            <div class="dropdown-menu" id="menu-<%= task._id %>" style="top: 26px; right: 0;">
                <a href="#" onclick="event.preventDefault(); openEditModal('<%= JSON.stringify(task) %>')">Edit Task</a>
                <a href="#" class="delete-link" onclick="event.preventDefault(); deleteTaskPrompt('<%= task._id %>', '<%= task.title %>')">Delete Task</a>
            </div>
        </div>
    </div>

    <h3><%= task.title %></h3>
    <% if (task.description) { %>
        <p class="task-desc-preview"><%= task.description %></p>
    <% } else { %>
        <p class="task-desc-preview" style="font-style: italic; color: rgba(255,255,255,0.25);">No details logged.</p>
    <% } %>

    <div class="task-card-footer">
        <span class="task-project-tag" title="<%= task.projectId ? task.projectId.name : 'General Task' %>">
            <%= task.projectId ? task.projectId.name : 'General Task' %>
        </span>
        <div style="display: flex; align-items: center; gap: 4px;">
            <i data-lucide="calendar" style="width: 12px; height: 12px; color: rgba(255,255,255,0.3);"></i>
            <span><%= task.dueDate ? new Date(task.dueDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : 'No Target' %></span>
        </div>
    </div>
</div>
