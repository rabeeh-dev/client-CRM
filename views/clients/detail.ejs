<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/pages/leads.css">
    <link rel="stylesheet" href="/css/pages/clients.css">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body>
    <div class="app-layout">
        
        <!-- Sidebar Navigation -->
        <%- include('../partials/sidebar') %>

        <!-- Main View Frame -->
        <div class="view-frame">
            <!-- Header Row -->
            <%- include('../partials/header', {
                breadcrumbs: [
                    { label: 'Clients' },
                    { label: clientRecord.name, active: true }
                ]
            }) %>

            <!-- Scrollable View Body -->
            <main class="view-body">
                <!-- Action Header Panel -->
                <section class="detail-action-header">
                    <div class="lead-identity">
                        <div class="clientRecord-avatar-large">
                            <%= clientRecord.name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase() %>
                        </div>
                        <div style="display: flex; flex-direction: column; gap: 4px;">
                            <h1><%= clientRecord.name %></h1>
                            <div class="badges-row">
                                <span class="status-badge status-<%= clientRecord.status %>"><%= clientRecord.status %></span>
                                <div class="star-rating">
                                    <% for(let i = 1; i <= 5; i++) { %>
                                        <svg viewBox="0 0 24 24" width="14" height="14" fill="<%= i <= clientRecord.rating ? 'var(--warning)' : 'none' %>" stroke="var(--warning)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="header-buttons">
                        <a href="/clients" class="btn btn-secondary">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                            <span>Back to List</span>
                        </a>
                        <button class="btn btn-secondary" id="openEditClientBtn">
                            <i data-lucide="edit"></i>
                            <span>Edit</span>
                        </button>
                        <button class="btn btn-danger" onclick="deleteClientPrompt('<%= clientRecord._id %>', '<%= clientRecord.name %>')">
                            <i data-lucide="trash-2"></i>
                            <span>Delete</span>
                        </button>
                    </div>
                </section>

                <!-- Two-Column Layout -->
                <div class="content-split">
                    <!-- Left: Overview Panel -->
                    <div class="details-sidebar">
                        <div class="panel">
                            <div class="panel-header">
                                <h2>Client Details</h2>
                            </div>
                            <div class="panel-content details-list">
                                <div class="detail-row">
                                    <span class="label">Company</span>
                                    <span class="val"><%= clientRecord.company || 'Individual' %></span>
                                </div>
                                <div class="detail-row">
                                    <span class="label">Email Address</span>
                                    <span class="val"><%= clientRecord.email || 'Not Provided' %></span>
                                </div>
                                <div class="detail-row">
                                    <span class="label">Phone Number</span>
                                    <span class="val"><%= clientRecord.phone || 'Not Provided' %></span>
                                </div>
                                
                                <!-- Social Profiles Section -->
                                <% if (clientRecord.socialMedia && (clientRecord.socialMedia.linkedin || clientRecord.socialMedia.twitter || clientRecord.socialMedia.instagram || clientRecord.socialMedia.whatsapp)) { %>
                                    <div class="detail-row social-row">
                                        <span class="label">Social Links</span>
                                        <span class="val social-links">
                                            <% if (clientRecord.socialMedia.linkedin) { %>
                                                <a href="<%= clientRecord.socialMedia.linkedin %>" target="_blank" title="LinkedIn" class="social-icon linkedin">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                                                </a>
                                            <% } %>
                                            <% if (clientRecord.socialMedia.twitter) { %>
                                                <a href="<%= clientRecord.socialMedia.twitter %>" target="_blank" title="Twitter/X" class="social-icon twitter">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
                                                </a>
                                            <% } %>
                                            <% if (clientRecord.socialMedia.instagram) { %>
                                                <a href="<%= clientRecord.socialMedia.instagram %>" target="_blank" title="Instagram" class="social-icon instagram">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                                                </a>
                                            <% } %>
                                            <% if (clientRecord.socialMedia.whatsapp) { %>
                                                <a href="<%= clientRecord.socialMedia.whatsapp %>" target="_blank" title="WhatsApp" class="social-icon whatsapp">
                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                                                </a>
                                            <% } %>
                                        </span>
                                    </div>
                                <% } %>
                            </div>
                        </div>

                        <!-- Private Internal Notes -->
                        <div class="panel">
                            <div class="panel-header">
                                <h2>Internal Notes</h2>
                            </div>
                            <div class="panel-content">
                                <div class="rich-notes-box">
                                    <%= clientRecord.notes || 'No internal requirements or billing arrangements logged. Click Edit to add notes.' %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Sub-Resource Tabs -->
                    <div class="details-main">
                        <div class="tabs-container">
                            <div class="tabs-header">
                                <button class="tab-btn active" onclick="switchTab(event, 'projectsTab')">Projects</button>
                                <button class="tab-btn" onclick="switchTab(event, 'timelineTab')">Activity Timeline</button>
                            </div>

                            <!-- Projects Tab -->
                            <div class="tab-content active" id="projectsTab">
                                <div class="tab-section-header">
                                    <h3>Client Projects</h3>
                                    <button class="btn btn-secondary btn-sm" id="openAddProjectBtn">
                                        <i data-lucide="plus"></i>
                                        <span>Add Project</span>
                                    </button>
                                </div>
                                <div class="projects-list">
                                    <% if (projects.length === 0) { %>
                                        <div class="empty-state-small">
                                            <p>No projects recorded for this clientRecord.</p>
                                        </div>
                                    <% } else { %>
                                        <% projects.forEach(project => { %>
                                            <div class="project-item" onclick="window.location.href='/projects/<%= project._id %>'" style="cursor: pointer;">
                                                <div class="project-meta-row">
                                                    <h4 class="project-name"><%= project.name %></h4>
                                                    <span class="status-badge status-<%= project.status %>"><%= project.status.replace(/_/g, ' ') %></span>
                                                </div>
                                                <p class="project-desc"><%= project.description || 'No project description logged.' %></p>
                                                <div class="project-details-grid">
                                                    <div>
                                                        <span class="label">Value:</span>
                                                        <span class="amount-text"><%= project.value.toLocaleString('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }) %></span>
                                                    </div>
                                                    <div>
                                                        <span class="label">Timeline:</span>
                                                        <span class="time-text">
                                                            <%= project.startDate ? new Date(project.startDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'N/A' %> - 
                                                            <%= project.endDate ? new Date(project.endDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'N/A' %>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }) %>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Activity Timeline Tab -->
                            <div class="tab-content" id="timelineTab">
                                <div class="tab-section-header">
                                    <h3>Activity Timeline</h3>
                                    <button class="btn btn-secondary btn-sm" id="openAddActivityBtn">
                                        <i data-lucide="plus"></i>
                                        <span>Log Activity</span>
                                    </button>
                                </div>
                                
                                <div class="timeline-list">
                                    <% if (activities.length === 0) { %>
                                        <div class="empty-state-small">
                                            <p>No activities recorded yet.</p>
                                        </div>
                                    <% } else { %>
                                        <% activities.forEach(act => { %>
                                            <div class="timeline-item">
                                                <div class="timeline-icon">
                                                    <% if (act.type === 'project') { %>
                                                        <i data-lucide="folder"></i>
                                                    <% } else if (act.type === 'payment') { %>
                                                        <i data-lucide="credit-card"></i>
                                                    <% } else if (act.type === 'document') { %>
                                                        <i data-lucide="file-text"></i>
                                                    <% } else if (act.type === 'email') { %>
                                                        <i data-lucide="mail"></i>
                                                    <% } else if (act.type === 'call') { %>
                                                        <i data-lucide="phone"></i>
                                                    <% } else if (act.type === 'meeting') { %>
                                                        <i data-lucide="users"></i>
                                                    <% } else { %>
                                                        <i data-lucide="activity"></i>
                                                    <% } %>
                                                </div>
                                                <div class="timeline-content">
                                                    <div class="timeline-meta">
                                                        <span class="action"><%= act.type.toUpperCase() %> EVENT</span>
                                                        <span class="time"><%= new Date(act.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
                                                    </div>
                                                    <p class="desc"><%= act.description %></p>
                                                </div>
                                            </div>
                                        <% }) %>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Modal: Edit Client -->
    <div class="modal-backdrop" id="editClientModal">
        <div class="modal-container">
            <div class="modal-header">
                <h2>Edit Client Details</h2>
                <button class="modal-close" onclick="closeModal('editClientModal')">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <form id="editClientForm" class="modal-form">
                <!-- Section 1: Client Information -->
                <div class="form-section-title">Client Information</div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="edit_name">Full Name *</label>
                        <input type="text" id="edit_name" value="<%= clientRecord.name %>" required>
                    </div>
                    <div class="form-group">
                        <label for="edit_company">Company Name</label>
                        <input type="text" id="edit_company" value="<%= clientRecord.company || '' %>">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="edit_rating">Client Rating</label>
                        <select id="edit_rating">
                            <option value="5" <%= clientRecord.rating === 5 ? 'selected' : '' %>>5 Stars</option>
                            <option value="4" <%= clientRecord.rating === 4 ? 'selected' : '' %>>4 Stars</option>
                            <option value="3" <%= clientRecord.rating === 3 ? 'selected' : '' %>>3 Stars</option>
                            <option value="2" <%= clientRecord.rating === 2 ? 'selected' : '' %>>2 Stars</option>
                            <option value="1" <%= clientRecord.rating === 1 ? 'selected' : '' %>>1 Star</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="edit_status">Relationship Status</label>
                        <select id="edit_status">
                            <option value="active" <%= clientRecord.status === 'active' ? 'selected' : '' %>>Active</option>
                            <option value="inactive" <%= clientRecord.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                        </select>
                    </div>
                </div>

                <!-- Section 2: Contact Details -->
                <div class="form-section-title">Contact Details</div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="edit_email">Email Address</label>
                        <input type="email" id="edit_email" value="<%= clientRecord.email || '' %>">
                    </div>
                    <div class="form-group">
                        <label for="edit_phone">Phone Number</label>
                        <input type="text" id="edit_phone" value="<%= clientRecord.phone || '' %>">
                    </div>
                </div>

                <!-- Section 3: Social Links -->
                <div class="form-section-title">Social Links</div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="edit_linkedin">LinkedIn URL</label>
                        <input type="url" id="edit_linkedin" value="<%= (clientRecord.socialMedia && clientRecord.socialMedia.linkedin) || '' %>">
                    </div>
                    <div class="form-group">
                        <label for="edit_twitter">Twitter/X URL</label>
                        <input type="url" id="edit_twitter" value="<%= (clientRecord.socialMedia && clientRecord.socialMedia.twitter) || '' %>">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="edit_instagram">Instagram URL</label>
                        <input type="url" id="edit_instagram" value="<%= (clientRecord.socialMedia && clientRecord.socialMedia.instagram) || '' %>">
                    </div>
                    <div class="form-group">
                        <label for="edit_whatsapp">WhatsApp Direct URL</label>
                        <input type="url" id="edit_whatsapp" value="<%= (clientRecord.socialMedia && clientRecord.socialMedia.whatsapp) || '' %>">
                    </div>
                </div>

                <!-- Section 4: Internal Notes -->
                <div class="form-section-title">Internal Notes</div>
                <div class="form-group">
                    <label for="edit_notes">Notes</label>
                    <textarea id="edit_notes" rows="3"><%= clientRecord.notes || '' %></textarea>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeModal('editClientModal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Client</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal: Add Project -->
    <div class="modal-backdrop" id="addProjectModal">
        <div class="modal-container">
            <div class="modal-header">
                <h2>Add Client Project</h2>
                <button class="modal-close" onclick="closeModal('addProjectModal')">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <form id="addProjectForm" class="modal-form">
                <div class="form-row">
                    <div class="form-group">
                        <label for="proj_name">Project Name *</label>
                        <input type="text" id="proj_name" placeholder="Acme Web Development" required>
                    </div>
                    <div class="form-group">
                        <label for="proj_value">Project Value (₹)</label>
                        <input type="number" id="proj_value" placeholder="100000" min="0">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="proj_status">Status</label>
                        <select id="proj_status">
                            <option value="planning">Planning</option>
                            <option value="in_progress" selected>In Progress</option>
                            <option value="completed">Completed</option>
                            <option value="on_hold">On Hold</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="proj_start">Start Date</label>
                        <input type="date" id="proj_start">
                    </div>
                    <div class="form-group">
                        <label for="proj_end">End Date</label>
                        <input type="date" id="proj_end">
                    </div>
                </div>
                <div class="form-group">
                    <label for="proj_desc">Project Description</label>
                    <textarea id="proj_desc" rows="3" placeholder="Brief scope of work, technical requirements, or milestones..."></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeModal('addProjectModal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Project</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal: Log Activity -->
    <div class="modal-backdrop" id="logActivityModal">
        <div class="modal-container">
            <div class="modal-header">
                <h2>Log Manual Interaction</h2>
                <button class="modal-close" onclick="closeModal('logActivityModal')">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <form id="logActivityForm" class="modal-form">
                <div class="form-row">
                    <div class="form-group">
                        <label for="act_type">Event Type</label>
                        <select id="act_type">
                            <option value="call" selected>Phone Call</option>
                            <option value="meeting">Meeting Session</option>
                            <option value="note">Internal Review Note</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label for="act_desc">Activity Description *</label>
                    <textarea id="act_desc" rows="4" placeholder="Detailed description of call summary, meeting agenda, or internal review findings..." required></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeModal('logActivityModal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Log Event</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Custom Toast & Confirmation Modals -->
    <div class="toast-container" id="toastContainer"></div>

    <div class="confirm-backdrop" id="confirmModal">
        <div class="confirm-card">
            <div class="confirm-icon danger" id="confirmIcon">
                <i data-lucide="alert-triangle"></i>
            </div>
            <h3 id="confirmTitle">Confirm Action</h3>
            <p id="confirmMessage">Are you sure you want to proceed?</p>
            <div class="confirm-actions">
                <button class="btn btn-secondary" onclick="closeConfirmDialog()">Cancel</button>
                <button class="btn btn-danger" id="confirmExecuteBtn">Confirm</button>
            </div>
        </div>
    </div>

    <!-- Script Init -->
    <script>
        lucide.createIcons();

        // Toast Helper
        function showToast(message, type = 'success') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            
            let iconName = 'check-circle';
            if (type === 'danger') iconName = 'alert-circle';
            if (type === 'info') iconName = 'info';

            toast.innerHTML = `
                <div class="toast-icon-box">
                    <i data-lucide="${iconName}"></i>
                </div>
                <span>${message}</span>
            `;
            
            container.appendChild(toast);
            lucide.createIcons();

            setTimeout(() => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Confirmation Dialog Helpers
        let currentConfirmCallback = null;
        function showConfirmDialog(title, message, onConfirm) {
            document.getElementById('confirmTitle').innerText = title;
            document.getElementById('confirmMessage').innerText = message;
            currentConfirmCallback = onConfirm;
            document.getElementById('confirmModal').classList.add('active');
        }
        function closeConfirmDialog() {
            document.getElementById('confirmModal').classList.remove('active');
            currentConfirmCallback = null;
        }
        document.getElementById('confirmExecuteBtn').addEventListener('click', () => {
            if (currentConfirmCallback) {
                currentConfirmCallback();
            }
            closeConfirmDialog();
        });

        // Tab switcher
        function switchTab(evt, tabId) {
            const contents = document.querySelectorAll('.tab-content');
            const buttons = document.querySelectorAll('.tab-btn');

            contents.forEach(c => c.classList.remove('active'));
            buttons.forEach(b => b.classList.remove('active'));

            document.getElementById(tabId).classList.add('active');
            evt.currentTarget.classList.add('active');
        }

        // Close modal helper
        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        }

        // Edit Client Modal Triggers
        document.getElementById('openEditClientBtn').addEventListener('click', () => {
            document.getElementById('editClientModal').classList.add('active');
        });

        document.getElementById('editClientForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const payload = {
                name: document.getElementById('edit_name').value,
                company: document.getElementById('edit_company').value,
                rating: document.getElementById('edit_rating').value,
                status: document.getElementById('edit_status').value,
                email: document.getElementById('edit_email').value,
                phone: document.getElementById('edit_phone').value,
                linkedin: document.getElementById('edit_linkedin').value,
                twitter: document.getElementById('edit_twitter').value,
                instagram: document.getElementById('edit_instagram').value,
                whatsapp: document.getElementById('edit_whatsapp').value,
                notes: document.getElementById('edit_notes').value
            };

            fetch('/clients/<%= clientRecord._id %>', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('editClientModal');
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showToast(data.message || 'Error updating clientRecord', 'danger');
                }
            })
            .catch(err => {
                console.error(err);
                showToast('Server connection error', 'danger');
            });
        });

        // Delete Client
        function deleteClientPrompt(id, name) {
            showConfirmDialog(
                'Delete Client',
                `Are you sure you want to delete clientRecord '${name}' and all associated projects, invoices, and documents? This action is permanent.`,
                () => {
                    fetch(`/clients/${id}`, { method: 'DELETE' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            showToast(data.message, 'success');
                            setTimeout(() => window.location.href = '/clients', 1000);
                        } else {
                            showToast(data.message || 'Error deleting clientRecord', 'danger');
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        showToast('Server connection error', 'danger');
                    });
                }
            );
        }

        // Add Project triggers
        document.getElementById('openAddProjectBtn').addEventListener('click', () => {
            document.getElementById('addProjectModal').classList.add('active');
        });
        document.getElementById('addProjectForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const payload = {
                name: document.getElementById('proj_name').value,
                value: document.getElementById('proj_value').value,
                status: document.getElementById('proj_status').value,
                startDate: document.getElementById('proj_start').value,
                endDate: document.getElementById('proj_end').value,
                description: document.getElementById('proj_desc').value
            };
            fetch('/clients/<%= clientRecord._id %>/projects', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('addProjectModal');
                    document.getElementById('addProjectForm').reset();
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showToast(data.message || 'Error creating project', 'danger');
                }
            });
        });

        // Log Activity triggers
        document.getElementById('openAddActivityBtn').addEventListener('click', () => {
            document.getElementById('logActivityModal').classList.add('active');
        });
        document.getElementById('logActivityForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const payload = {
                type: document.getElementById('act_type').value,
                description: document.getElementById('act_desc').value
            };
            fetch('/clients/<%= clientRecord._id %>/activities', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('logActivityModal');
                    document.getElementById('logActivityForm').reset();
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showToast(data.message || 'Error logging activity', 'danger');
                }
            });
        });
    </script>
</body>
</html>
