<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/pages/leads.css">
    <link rel="stylesheet" href="/css/pages/clients.css">
    <link rel="stylesheet" href="/css/pages/projects.css">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body>
    <div class="app-layout">
        
        <!-- Sidebar Navigation -->
        <%- include('../partials/sidebar') %>

        <!-- Main View Frame -->
        <div class="view-frame">
            <!-- Header Row -->
            <%- include('../partials/header', {
                breadcrumbs: [
                    { label: 'Workspace' },
                    { label: 'Projects', active: true }
                ]
            }) %>

            <!-- Scrollable View Body -->
            <main class="view-body">
                <!-- Header panel -->
                <section class="leads-header">
                    <div>
                        <h1>Projects Workspace</h1>
                        <p>Track active client projects, budget values, checklist progression, and deadlines.</p>
                    </div>
                    <button class="btn btn-primary" id="openAddProjectBtn">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                        <span>Add Project</span>
                    </button>
                </section>

                <!-- Metrics grid -->
                <section class="metrics-grid">
                    <div class="metric-card">
                        <span class="title">Total Portfolio Budget</span>
                        <div class="value">
                            <%= metrics.totalBudget.toLocaleString('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }) %>
                        </div>
                    </div>
                    <div class="metric-card">
                        <span class="title">Active Projects</span>
                        <div class="value"><%= metrics.activeProjects %></div>
                    </div>
                    <div class="metric-card">
                        <span class="title">Completed Projects</span>
                        <div class="value"><%= metrics.completedProjects %></div>
                    </div>
                    <div class="metric-card">
                        <span class="title">On Hold</span>
                        <div class="value"><%= metrics.onHoldProjects %></div>
                    </div>
                </section>

                <!-- Search and Filters Panel -->
                <section class="filter-panel">
                    <form action="/projects" method="GET" class="filter-form" id="projectsFilterForm">
                        <div class="search-input">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                            <input type="text" name="search" placeholder="Search projects by name..." value="<%= filters.search %>">
                        </div>
                        
                        <div class="select-wrapper">
                            <select name="status" onchange="this.form.submit()">
                                <option value="" <%= filters.status === '' ? 'selected' : '' %>>All Statuses</option>
                                <option value="planning" <%= filters.status === 'planning' ? 'selected' : '' %>>Planning</option>
                                <option value="in_progress" <%= filters.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
                                <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
                                <option value="on_hold" <%= filters.status === 'on_hold' ? 'selected' : '' %>>On Hold</option>
                            </select>
                        </div>

                        <div class="select-wrapper">
                            <select name="priority" onchange="this.form.submit()">
                                <option value="" <%= filters.priority === '' ? 'selected' : '' %>>All Priorities</option>
                                <option value="low" <%= filters.priority === 'low' ? 'selected' : '' %>>Low</option>
                                <option value="medium" <%= filters.priority === 'medium' ? 'selected' : '' %>>Medium</option>
                                <option value="high" <%= filters.priority === 'high' ? 'selected' : '' %>>High</option>
                            </select>
                        </div>

                        <div class="select-wrapper">
                            <select name="clientId" onchange="this.form.submit()">
                                <option value="" <%= filters.clientId === '' ? 'selected' : '' %>>All Clients</option>
                                <% clients.forEach(client => { %>
                                    <option value="<%= client._id %>" <%= filters.clientId === client._id.toString() ? 'selected' : '' %>><%= client.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        
                        <% if (filters.search || filters.status || filters.priority || filters.clientId) { %>
                            <a href="/projects" class="btn btn-clear">Clear Filters</a>
                        <% } %>
                    </form>
                </section>

                <!-- Projects Card Grid -->
                <section class="leads-grid">
                    <% if (projects.length === 0) { %>
                        <div class="empty-state">
                            <i data-lucide="folder" class="empty-icon"></i>
                            <h3>No projects found</h3>
                            <p>Try modifying your filters, or click below to launch a new project.</p>
                            <button class="btn btn-primary" onclick="document.getElementById('openAddProjectBtn').click()">Add Project</button>
                        </div>
                    <% } else { %>
                        <% projects.forEach(project => { %>
                            <div class="lead-card status-<%= project.status %>" onclick="window.location.href='/projects/<%= project._id %>'" style="cursor: pointer;" data-project="<%= JSON.stringify(project) %>">
                                <div class="card-header">
                                    <div class="lead-meta" style="flex-wrap: wrap; gap: 6px;">
                                        <span class="status-badge status-<%= project.status %>"><%= project.status.replace(/_/g, ' ') %></span>
                                        <span class="priority-badge priority-<%= project.priority %>"><%= project.priority %></span>
                                    </div>
                                    <button class="dropdown-trigger" onclick="event.stopPropagation(); toggleCardMenu('<%= project._id %>')">
                                        <i data-lucide="more-vertical"></i>
                                    </button>
                                    <div class="dropdown-menu" id="menu-<%= project._id %>">
                                        <a href="/projects/<%= project._id %>">Open Workspace</a>
                                        <a href="#" onclick="event.preventDefault(); event.stopPropagation(); openEditModal(this.closest('.lead-card').dataset.project)">Edit Details</a>
                                        <a href="#" class="delete-link" onclick="event.preventDefault(); event.stopPropagation(); deleteProjectPrompt('<%= project._id %>', this.closest('.lead-card').querySelector('h3').innerText)">Delete Project</a>
                                    </div>
                                </div>

                                <div class="card-body">
                                    <h3><%= project.name %></h3>
                                    <p class="company" style="font-size: 13px; color: rgba(255, 255, 255, 0.5); margin-top: 4px; display: flex; align-items: center; gap: 6px;">
                                        <i data-lucide="building-2" style="width: 13px; height: 13px;"></i>
                                        <span><%= project.clientId ? project.clientId.name : 'Unassigned Client' %></span>
                                    </p>
                                    <% if (project.description) { %>
                                        <p class="desc-preview" style="font-size: 13px; color: rgba(255, 255, 255, 0.4); margin-top: 8px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= project.description %></p>
                                    <% } else { %>
                                        <p class="desc-preview" style="font-size: 13px; color: rgba(255, 255, 255, 0.25); margin-top: 8px; font-style: italic;">No description provided.</p>
                                    <% } %>

                                    <!-- Budget & Deadline row -->
                                    <div class="project-card-meta">
                                        <div>
                                            <span class="label">Budget</span>
                                            <span class="val"><%= (project.budget || project.value || 0).toLocaleString('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }) %></span>
                                        </div>
                                        <div>
                                            <span class="label">Deadline</span>
                                            <span class="val">
                                                <%= project.endDate ? new Date(project.endDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'No Date Set' %>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </section>
            </main>
        </div>
    </div>

    <!-- Modal: Add Project -->
    <div class="modal-backdrop" id="addProjectModal">
        <div class="modal-container">
            <div class="modal-header">
                <h2>Launch New Project</h2>
                <button class="modal-close" onclick="closeModal('addProjectModal')">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <form id="addProjectForm" class="modal-form">
                <div class="form-row">
                    <div class="form-group">
                        <label for="new_name">Project Name *</label>
                        <input type="text" id="new_name" placeholder="Acme Web Development" required>
                    </div>
                    <div class="form-group">
                        <label for="new_client">Assign Client *</label>
                        <select id="new_client" required>
                            <option value="">Select a Client...</option>
                            <% clients.forEach(c => { %>
                                <option value="<%= c._id %>"><%= c.name %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="new_budget">Project Budget (₹) *</label>
                        <input type="number" id="new_budget" placeholder="150000" min="0" required>
                    </div>
                    <div class="form-group">
                        <label for="new_deadline">Deadline Date</label>
                        <input type="date" id="new_deadline">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="new_status">Initial Status</label>
                        <select id="new_status">
                            <option value="planning" selected>Planning</option>
                            <option value="in_progress">In Progress</option>
                            <option value="completed">Completed</option>
                            <option value="on_hold">On Hold</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="new_priority">Project Priority</label>
                        <select id="new_priority">
                            <option value="low">Low Priority</option>
                            <option value="medium" selected>Medium Priority</option>
                            <option value="high">High Priority</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label for="new_desc">Project Description & Scope</label>
                    <textarea id="new_desc" rows="4" placeholder="Milestones scope, engineering requirements, key technical criteria..."></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeModal('addProjectModal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Project</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal: Edit Project -->
    <div class="modal-backdrop" id="editProjectModal">
        <div class="modal-container">
            <div class="modal-header">
                <h2>Edit Project Details</h2>
                <button class="modal-close" onclick="closeModal('editProjectModal')">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <form id="editProjectForm" class="modal-form">
                <input type="hidden" id="edit_id">
                <div class="form-row">
                    <div class="form-group">
                        <label for="edit_name">Project Name *</label>
                        <input type="text" id="edit_name" required>
                    </div>
                    <div class="form-group">
                        <label for="edit_client">Assign Client *</label>
                        <select id="edit_client" required>
                            <% clients.forEach(c => { %>
                                <option value="<%= c._id %>"><%= c.name %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="edit_budget">Project Budget (₹) *</label>
                        <input type="number" id="edit_budget" min="0" required>
                    </div>
                    <div class="form-group">
                        <label for="edit_deadline">Deadline Date</label>
                        <input type="date" id="edit_deadline">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="edit_status">Project Status</label>
                        <select id="edit_status">
                            <option value="planning">Planning</option>
                            <option value="in_progress">In Progress</option>
                            <option value="completed">Completed</option>
                            <option value="on_hold">On Hold</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="edit_priority">Project Priority</label>
                        <select id="edit_priority">
                            <option value="low">Low Priority</option>
                            <option value="medium">Medium Priority</option>
                            <option value="high">High Priority</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label for="edit_desc">Project Description & Scope</label>
                    <textarea id="edit_desc" rows="4"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeModal('editProjectModal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Project</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Custom Toast & Confirmation Modals -->
    <div class="toast-container" id="toastContainer"></div>

    <div class="confirm-backdrop" id="confirmModal">
        <div class="confirm-card">
            <div class="confirm-icon danger" id="confirmIcon">
                <i data-lucide="alert-triangle"></i>
            </div>
            <h3 id="confirmTitle">Confirm Action</h3>
            <p id="confirmMessage">Are you sure you want to proceed?</p>
            <div class="confirm-actions">
                <button class="btn btn-secondary" onclick="closeConfirmDialog()">Cancel</button>
                <button class="btn btn-danger" id="confirmExecuteBtn">Confirm</button>
            </div>
        </div>
    </div>

    <!-- Client-side Scripts -->
    <script>
        lucide.createIcons();

        // Menu Dropdown toggle
        function toggleCardMenu(id) {
            const dropdown = document.getElementById(`menu-${id}`);
            const isActive = dropdown.classList.contains('active');
            
            // Close all dropdowns first
            document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('active'));
            
            if (!isActive) {
                dropdown.classList.add('active');
            }
        }

        // Close dropdowns on document click
        document.addEventListener('click', () => {
            document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('active'));
        });

        // Toast Helper
        function showToast(message, type = 'success') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            
            let iconName = 'check-circle';
            if (type === 'danger') iconName = 'alert-circle';
            if (type === 'info') iconName = 'info';

            toast.innerHTML = `
                <div class="toast-icon-box">
                    <i data-lucide="${iconName}"></i>
                </div>
                <span>${message}</span>
            `;
            
            container.appendChild(toast);
            lucide.createIcons();

            setTimeout(() => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Confirmation Dialog Helpers
        let currentConfirmCallback = null;
        function showConfirmDialog(title, message, onConfirm) {
            document.getElementById('confirmTitle').innerText = title;
            document.getElementById('confirmMessage').innerText = message;
            currentConfirmCallback = onConfirm;
            document.getElementById('confirmModal').classList.add('active');
        }
        function closeConfirmDialog() {
            document.getElementById('confirmModal').classList.remove('active');
            currentConfirmCallback = null;
        }
        document.getElementById('confirmExecuteBtn').addEventListener('click', () => {
            if (currentConfirmCallback) {
                currentConfirmCallback();
            }
            closeConfirmDialog();
        });

        // Close modal helper
        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        }

        // Modal triggers
        document.getElementById('openAddProjectBtn').addEventListener('click', () => {
            document.getElementById('addProjectModal').classList.add('active');
        });

        // Add Project Submit
        document.getElementById('addProjectForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const payload = {
                name: document.getElementById('new_name').value,
                clientId: document.getElementById('new_client').value,
                budget: document.getElementById('new_budget').value,
                deadline: document.getElementById('new_deadline').value,
                status: document.getElementById('new_status').value,
                priority: document.getElementById('new_priority').value,
                description: document.getElementById('new_desc').value
            };

            fetch('/projects', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('addProjectModal');
                    document.getElementById('addProjectForm').reset();
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showToast(data.message || 'Error creating project', 'danger');
                }
            })
            .catch(err => {
                console.error(err);
                showToast('Server connection error', 'danger');
            });
        });

        // Open Edit Modal
        function openEditModal(projectData) {
            const project = typeof projectData === 'string' ? JSON.parse(projectData) : projectData;
            document.getElementById('edit_id').value = project._id;
            document.getElementById('edit_name').value = project.name;
            document.getElementById('edit_client').value = project.clientId._id || project.clientId;
            document.getElementById('edit_budget').value = project.budget || project.value || 0;
            
            if (project.endDate) {
                const dateVal = new Date(project.endDate).toISOString().split('T')[0];
                document.getElementById('edit_deadline').value = dateVal;
            } else {
                document.getElementById('edit_deadline').value = '';
            }

            document.getElementById('edit_status').value = project.status;
            document.getElementById('edit_priority').value = project.priority;
            document.getElementById('edit_desc').value = project.description || '';

            document.getElementById('editProjectModal').classList.add('active');
        }

        // Update Project Submit
        document.getElementById('editProjectForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const id = document.getElementById('edit_id').value;
            const payload = {
                name: document.getElementById('edit_name').value,
                clientId: document.getElementById('edit_client').value,
                budget: document.getElementById('edit_budget').value,
                deadline: document.getElementById('edit_deadline').value,
                status: document.getElementById('edit_status').value,
                priority: document.getElementById('edit_priority').value,
                description: document.getElementById('edit_desc').value
            };

            fetch(`/projects/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    closeModal('editProjectModal');
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showToast(data.message || 'Error updating project', 'danger');
                }
            })
            .catch(err => {
                console.error(err);
                showToast('Server connection error', 'danger');
            });
        });

        // Delete Project prompt
        function deleteProjectPrompt(id, name) {
            showConfirmDialog(
                'Delete Project',
                `Are you sure you want to delete the project '${name}' and all associated tasks? This action cannot be undone.`,
                () => {
                    fetch(`/projects/${id}`, { method: 'DELETE' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            showToast(data.message, 'success');
                            setTimeout(() => window.location.reload(), 1000);
                        } else {
                            showToast(data.message || 'Error deleting project', 'danger');
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        showToast('Server connection error', 'danger');
                    });
                }
            );
        }
    </script>
</body>
</html>
