<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/pages/leads.css">
    <link rel="stylesheet" href="/css/pages/clients.css">
    <link rel="stylesheet" href="/css/pages/payments.css">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body>
    <div class="app-layout">
        
        <!-- Sidebar Navigation -->
        <%- include('../partials/sidebar') %>

        <!-- Main View Frame -->
        <div class="view-frame">
            <!-- Header Row -->
            <%- include('../partials/header', {
                breadcrumbs: [
                    { label: 'Workspace' },
                    { label: 'Payments', link: '/payments' },
                    { label: 'Receipt Details', active: true }
                ]
            }) %>

            <!-- Scrollable View Body -->
            <main class="view-body">
                
                <!-- Action Header Panel -->
                <section class="detail-action-header" style="margin-bottom: 24px;">
                    <div class="lead-identity">
                        <h1>Payment Receipt #<%= payment.invoiceNumber %></h1>
                        <div class="badges-row">
                            <span class="status-badge status-<%= payment.status %>"><%= payment.status %></span>
                        </div>
                    </div>
                    
                    <div class="header-buttons">
                        <a href="/payments" class="btn btn-secondary">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                            <span>Back to List</span>
                        </a>
                    </div>
                </section>

                <!-- Two-Column Grid Layout -->
                <div class="content-split">
                    
                    <!-- LEFT COLUMN: Overview Cards -->
                    <div class="split-left">
                        
                        <!-- Panel 1: Invoice Financial Summary -->
                        <div class="panel">
                            <div class="panel-header">
                                <h2>Financial Summary</h2>
                            </div>
                            <div class="panel-content" style="padding-top: 10px;">
                                <div style="background: rgba(255, 255, 255, 0.01); border: 1px solid var(--border-color); padding: 18px; border-radius: 12px; display: flex; flex-direction: column; gap: 14px;">
                                    <div>
                                        <span style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: rgba(255, 255, 255, 0.4); letter-spacing: 0.5px;">Amount Received</span>
                                        <div style="font-size: 24px; font-weight: 700; color: var(--success); margin-top: 4px; font-family: 'Outfit';">
                                            <%= payment.amount.toLocaleString('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }) %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Panel: Settle Banner -->
                        <div class="panel" style="background: rgba(16, 185, 129, 0.02); border-color: rgba(16, 185, 129, 0.15); border-radius: 12px; padding: 20px; display: flex; align-items: center; gap: 12px; margin-top: 16px;">
                            <i data-lucide="check-circle" style="width: 24px; height: 24px; color: var(--success); flex-shrink: 0;"></i>
                            <div>
                                <h4 style="font-size: 14px; font-weight: 600; color: white;">Payment Logged & Settled</h4>
                                <p style="font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 2px;">This payment receipt has been successfully logged and recorded in full.</p>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT COLUMN: Metadata Details -->
                    <div class="split-right">
                        
                        <!-- Panel: Client Details -->
                        <div class="panel">
                            <div class="panel-header">
                                <h2>Client Account</h2>
                            </div>
                            <div class="panel-content details-list">
                                <% if (payment.clientId) { %>
                                    <div class="detail-row">
                                        <span class="label">Contact Person</span>
                                        <span class="val"><strong><%= payment.clientId.name %></strong></span>
                                    </div>
                                    <% if (payment.clientId.company) { %>
                                        <div class="detail-row">
                                            <span class="label">Company Name</span>
                                            <span class="val"><%= payment.clientId.company %></span>
                                        </div>
                                    <% } %>
                                    <% if (payment.clientId.email) { %>
                                        <div class="detail-row">
                                            <span class="label">Email Address</span>
                                            <span class="val" style="color: var(--primary);"><%= payment.clientId.email %></span>
                                        </div>
                                    <% } %>
                                    <% if (payment.clientId.phone) { %>
                                        <div class="detail-row">
                                            <span class="label">Phone Number</span>
                                            <span class="val"><%= payment.clientId.phone %></span>
                                        </div>
                                    <% } %>
                                <% } else { %>
                                    <div style="padding: 10px 0; font-style: italic; color: rgba(255,255,255,0.3);">No client assigned</div>
                                <% } %>
                            </div>
                        </div>

                        <!-- Panel: Project Association -->
                        <div class="panel">
                            <div class="panel-header">
                                <h2>Project Workspace</h2>
                            </div>
                            <div class="panel-content details-list">
                                <% if (payment.projectId) { %>
                                    <div class="detail-row">
                                        <span class="label">Project Title</span>
                                        <span class="val"><strong><%= payment.projectId.name %></strong></span>
                                    </div>
                                    <div class="detail-row">
                                        <span class="label">Contract Value</span>
                                        <span class="val amount-text">
                                            <%= (payment.projectId.budget || payment.projectId.value || 0).toLocaleString('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }) %>
                                        </span>
                                    </div>
                                    <div style="margin-top: 14px;">
                                        <a href="/projects/<%= payment.projectId._id %>" class="btn btn-secondary btn-sm" style="display: inline-flex; width: 100%; justify-content: center;">
                                            <span>Open Project Workspace</span>
                                        </a>
                                    </div>
                                <% } else { %>
                                    <div style="padding: 10px 0; font-style: italic; color: rgba(255,255,255,0.3);">General Billing Receipt</div>
                                <% } %>
                            </div>
                        </div>

                        <!-- Panel: Receipt Details -->
                        <div class="panel">
                            <div class="panel-header">
                                <h2>Receipt Details</h2>
                            </div>
                            <div class="panel-content details-list">
                                <div class="detail-row">
                                    <span class="label">Payment Date</span>
                                    <span class="val"><%= new Date(payment.paidDate || payment.dueDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
                                </div>
                                <div class="detail-row">
                                    <span class="label">Payment Method</span>
                                    <span class="val" style="text-transform: uppercase;"><%= payment.transactions[0] ? payment.transactions[0].method.replace('_', ' ') : 'BANK TRANSFER' %></span>
                                </div>
                                <div class="detail-row">
                                    <span class="label">Notes</span>
                                    <span class="val"><%= payment.transactions[0] && payment.transactions[0].notes ? payment.transactions[0].notes : 'None' %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Custom Toast & Confirmation Container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Client-side script -->
    <script>
        lucide.createIcons();


    </script>
</body>
</html>
