<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Client Workspace</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/pages/leads.css">
    <link rel="stylesheet" href="/css/pages/analytics.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body>
    <div class="app-layout">
        <%- include('../partials/sidebar', { activePage: 'analytics' }) %>
        
        <div class="view-frame">
            <%- include('../partials/header', {
                breadcrumbs: [
                    { label: 'Workspace', url: '/dashboard' },
                    { label: 'Analytics', active: true }
                ]
            }) %>
            
            <main class="view-body">
                <section class="leads-header">
                    <div>
                        <h1>Analytics</h1>
                        <p class="subtitle">Track your business performance and insights</p>
                    </div>
                </section>

                <!-- Business Overview -->
                <section class="analytics-metrics">
                    <div class="a-metric-card">
                        <div class="a-metric-icon" style="background: rgba(16,185,129,0.15); color: #10b981;">
                            <i data-lucide="dollar-sign"></i>
                        </div>
                        <div class="a-metric-info">
                            <span class="a-metric-label">Total Revenue</span>
                            <span class="a-metric-value">₹<%= overview.totalRevenue.toLocaleString() %></span>
                        </div>
                    </div>
                    <div class="a-metric-card">
                        <div class="a-metric-icon" style="background: rgba(99,102,241,0.15); color: #6366f1;">
                            <i data-lucide="users"></i>
                        </div>
                        <div class="a-metric-info">
                            <span class="a-metric-label">Total Clients</span>
                            <span class="a-metric-value"><%= overview.totalClients %></span>
                        </div>
                    </div>
                    <div class="a-metric-card">
                        <div class="a-metric-icon" style="background: rgba(59,130,246,0.15); color: #3b82f6;">
                            <i data-lucide="folder"></i>
                        </div>
                        <div class="a-metric-info">
                            <span class="a-metric-label">Total Projects</span>
                            <span class="a-metric-value"><%= overview.totalProjects %></span>
                        </div>
                    </div>
                    <div class="a-metric-card">
                        <div class="a-metric-icon" style="background: rgba(245,158,11,0.15); color: #f59e0b;">
                            <i data-lucide="activity"></i>
                        </div>
                        <div class="a-metric-info">
                            <span class="a-metric-label">Active Projects</span>
                            <span class="a-metric-value"><%= overview.activeProjects %></span>
                        </div>
                    </div>
                    <div class="a-metric-card">
                        <div class="a-metric-icon" style="background: rgba(16,185,129,0.15); color: #10b981;">
                            <i data-lucide="check-circle"></i>
                        </div>
                        <div class="a-metric-info">
                            <span class="a-metric-label">Completed Projects</span>
                            <span class="a-metric-value"><%= overview.completedProjects %></span>
                        </div>
                    </div>
                    <div class="a-metric-card">
                        <div class="a-metric-icon" style="background: rgba(139,92,246,0.15); color: #8b5cf6;">
                            <i data-lucide="target"></i>
                        </div>
                        <div class="a-metric-info">
                            <span class="a-metric-label">Total Leads</span>
                            <span class="a-metric-value"><%= overview.totalLeads %></span>
                        </div>
                    </div>
                </section>

                <div class="analytics-charts-row">
                    <div class="a-panel">
                        <div class="a-panel-header">
                            <h3>Monthly Revenue</h3>
                        </div>
                        <div class="a-panel-body">
                            <canvas id="monthlyRevenueChart"></canvas>
                        </div>
                    </div>
                    <div class="a-panel">
                        <div class="a-panel-header">
                            <h3>Client Revenue</h3>
                        </div>
                        <div class="a-panel-body">
                            <canvas id="clientRevenueChart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="analytics-charts-row">
                    <div class="a-panel">
                        <div class="a-panel-header">
                            <h3>Project Statistics</h3>
                        </div>
                        <div class="a-panel-body" style="display: flex; justify-content: center;">
                            <div style="width: 300px; height: 300px;">
                                <canvas id="projectStatsChart"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="a-panel">
                        <div class="a-panel-header">
                            <h3>Lead Conversion Funnel</h3>
                        </div>
                        <div class="a-panel-body">
                            <div class="a-conversion-rate">
                                <div class="rate-value"><%= leadConversionRate %>%</div>
                                <div class="rate-label">Conversion Rate</div>
                            </div>
                            <canvas id="leadFunnelChart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="analytics-tables-row">
                    <div class="a-panel">
                        <div class="a-panel-header">
                            <h3>Pending Payments</h3>
                        </div>
                        <div class="a-panel-body p-0">
                            <table class="a-table">
                                <thead>
                                    <tr>
                                        <th>Invoice</th>
                                        <th>Client</th>
                                        <th>Project</th>
                                        <th>Amount</th>
                                        <th>Due Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (pendingPayments.length === 0) { %>
                                        <tr><td colspan="6" style="text-align: center; color: var(--text-muted);">No pending payments</td></tr>
                                    <% } else { %>
                                        <% pendingPayments.forEach(payment => { %>
                                            <tr>
                                                <td><%= payment.invoiceNumber %></td>
                                                <td><%= payment.clientId ? payment.clientId.name : '-' %></td>
                                                <td><%= payment.projectId ? payment.projectId.name : '-' %></td>
                                                <td>₹<%= payment.amount.toLocaleString() %></td>
                                                <td><%= new Date(payment.dueDate).toLocaleDateString() %></td>
                                                <td>
                                                    <span class="a-badge a-badge-<%= payment.status === 'overdue' ? 'danger' : 'warning' %>">
                                                        <%= payment.status.charAt(0).toUpperCase() + payment.status.slice(1) %>
                                                    </span>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="a-panel">
                        <div class="a-panel-header">
                            <h3>Recently Completed Projects</h3>
                        </div>
                        <div class="a-panel-body p-0">
                            <table class="a-table">
                                <thead>
                                    <tr>
                                        <th>Project</th>
                                        <th>Client</th>
                                        <th>Budget</th>
                                        <th>Completed Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (completedProjectsList.length === 0) { %>
                                        <tr><td colspan="4" style="text-align: center; color: var(--text-muted);">No completed projects</td></tr>
                                    <% } else { %>
                                        <% completedProjectsList.forEach(project => { %>
                                            <tr>
                                                <td><%= project.name %></td>
                                                <td><%= project.clientId ? project.clientId.name : '-' %></td>
                                                <td>₹<%= project.budget.toLocaleString() %></td>
                                                <td><%= new Date(project.updatedAt).toLocaleDateString() %></td>
                                            </tr>
                                        <% }) %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </main>
        </div>
    </div>

    <script>
        lucide.createIcons();

        // Chart.js Default styling for dark theme
        Chart.defaults.color = '#94a3b8';
        Chart.defaults.borderColor = 'rgba(255,255,255,0.06)';
        
        // Data from EJS
        const monthlyLabels = <%- JSON.stringify(monthlyRevenue.labels) %>;
        const monthlyData = <%- JSON.stringify(monthlyRevenue.data) %>;
        const clientLabels = <%- JSON.stringify(clientRevenue.labels) %>;
        const clientData = <%- JSON.stringify(clientRevenue.data) %>;
        const projStatsData = [
            <%= projectStats.planning || 0 %>, 
            <%= projectStats.in_progress || 0 %>, 
            <%= projectStats.completed || 0 %>, 
            <%= projectStats.on_hold || 0 %>
        ];
        const leadFunnelData = [
            <%= leadStats.new || 0 %>, 
            <%= leadStats.contacted || 0 %>, 
            <%= leadStats.proposal_sent || 0 %>, 
            <%= leadStats.negotiation || 0 %>, 
            <%= leadStats.won || 0 %>, 
            <%= leadStats.lost || 0 %>
        ];

        // 1. Monthly Revenue Chart (Bar)
        new Chart(document.getElementById('monthlyRevenueChart'), {
            type: 'bar',
            data: {
                labels: monthlyLabels,
                datasets: [{
                    label: 'Revenue (₹)',
                    data: monthlyData,
                    backgroundColor: 'rgba(99, 102, 241, 0.8)',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });

        // 2. Client Revenue Chart (Horizontal Bar)
        new Chart(document.getElementById('clientRevenueChart'), {
            type: 'bar',
            data: {
                labels: clientLabels,
                datasets: [{
                    label: 'Revenue (₹)',
                    data: clientData,
                    backgroundColor: 'rgba(16, 185, 129, 0.8)',
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    x: { beginAtZero: true }
                }
            }
        });

        // 3. Project Statistics (Doughnut)
        new Chart(document.getElementById('projectStatsChart'), {
            type: 'doughnut',
            data: {
                labels: ['Planning', 'In Progress', 'Completed', 'On Hold'],
                datasets: [{
                    data: projStatsData,
                    backgroundColor: ['#f59e0b', '#3b82f6', '#10b981', '#ef4444'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });

        // 4. Lead Conversion Funnel (Horizontal Bar)
        new Chart(document.getElementById('leadFunnelChart'), {
            type: 'bar',
            data: {
                labels: ['New', 'Contacted', 'Proposal Sent', 'Negotiation', 'Won', 'Lost'],
                datasets: [{
                    label: 'Leads',
                    data: leadFunnelData,
                    backgroundColor: ['#94a3b8', '#8b5cf6', '#3b82f6', '#f59e0b', '#10b981', '#ef4444'],
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    x: { beginAtZero: true }
                }
            }
        });
    </script>
</body>
</html>
