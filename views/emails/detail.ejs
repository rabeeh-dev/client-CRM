<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Email Detail - Client Workspace</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/pages/leads.css">
    <link rel="stylesheet" href="/css/pages/emails.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body>
    <div class="app-layout">
        <%- include('../partials/sidebar', { activePage: 'emails' }) %>
        
        <div class="view-frame">
            <%- include('../partials/header', {
                breadcrumbs: [
                    { label: 'Workspace', url: '/dashboard' },
                    { label: 'Emails', url: '/emails' },
                    { label: 'Details', active: true }
                ]
            }) %>
            
            <main class="view-body">
                <section class="detail-action-header">
                    <div>
                        <a href="/emails" class="back-link">
                            <i data-lucide="arrow-left"></i> Back to Emails
                        </a>
                        <h1>Email Detail</h1>
                    </div>
                </section>

                <div class="email-detail-container">
                    <!-- Email Header Panel -->
                    <div class="panel email-header-panel">
                        <div class="email-subject-large">
                            <h2><%= emailRecord.subject %></h2>
                            <span class="badge badge-<%= 
                                emailRecord.deliveryStatus === 'delivered' ? 'success' : 
                                emailRecord.deliveryStatus === 'sent' ? 'primary' : 
                                emailRecord.deliveryStatus === 'pending' ? 'warning' : 'danger' 
                            %>">
                                <%= emailRecord.deliveryStatus.charAt(0).toUpperCase() + emailRecord.deliveryStatus.slice(1) %>
                            </span>
                        </div>
                        
                        <div class="email-meta-info">
                            <div class="meta-item">
                                <div class="avatar">
                                    <span class="avatar-text"><%= emailRecord.clientId ? emailRecord.clientId.name.charAt(0).toUpperCase() : '?' %></span>
                                </div>
                                <div class="meta-details">
                                    <span class="meta-label">To:</span>
                                    <span class="meta-value">
                                        <strong><%= emailRecord.clientId ? emailRecord.clientId.name : 'Unknown Client' %></strong> 
                                        &lt;<%= emailRecord.clientId ? emailRecord.clientId.email : '' %>&gt;
                                    </span>
                                </div>
                            </div>
                            <div class="meta-item time-info">
                                <span class="meta-date"><%= new Date(emailRecord.sentDate).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                                <span class="meta-time"><%= new Date(emailRecord.sentDate).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                            </div>
                        </div>
                    </div>

                    <!-- Email Content Panel -->
                    <div class="panel email-content-panel">
                        <div class="email-body">
                            <% 
                            // Simple text to HTML formatting for message body
                            const formattedMessage = emailRecord.message
                                .replace(/</g, '&lt;')
                                .replace(/>/g, '&gt;')
                                .replace(/\n/g, '<br>');
                            %>
                            <%- formattedMessage %>
                        </div>
                        
                        <% if (emailRecord.attachments && emailRecord.attachments.length > 0) { %>
                            <div class="email-attachments">
                                <h3><i data-lucide="paperclip"></i> Attachments (<%= emailRecord.attachments.length %>)</h3>
                                <div class="attachments-list">
                                    <% emailRecord.attachments.forEach(attachment => { %>
                                        <div class="attachment-item">
                                            <div class="attachment-icon">
                                                <i data-lucide="file"></i>
                                            </div>
                                            <div class="attachment-info">
                                                <span class="attachment-name"><%= attachment.filename %></span>
                                                <span class="attachment-size"><%= (attachment.size / 1024).toFixed(2) %> KB</span>
                                            </div>
                                            <a href="<%= attachment.url %>" class="btn btn-icon btn-sm" download>
                                                <i data-lucide="download"></i>
                                            </a>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>
                        <% } %>
                    </div>
                    

                </div>
            </main>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
